font pango:JetBrains Mono 11

exec --no-startup-id lxqt-policykit-agent

exec --no-startup-id dunst

# Tecla modificadora (Windows)
set $mod Mod4
exec_always --no-startup-id feh --bg-fill /home/dani/.wallpapers/mountain.jpg &

# Iniciar sesión
exec --no-startup-id dbus-update-activation-environment --systemd DISPLAY
exec --no-startup-id systemctl --user import-environment DISPLAY
# Bloqueo de pantalla con betterlockscreen
bindsym $mod+Shift+l exec betterlockscreen -l --display 1 --span 
# Gaps (espacios entre ventanas)
gaps inner 5
gaps outer 7
smart_gaps on
default_border pixel 0
# Picom (compositor para transparencias/sombras)
exec_always --no-startup-id picom -b --config ~/.config/picom/picom.conf

# Atajos básicos
bindsym $mod+Return exec alacritty
#bindsym $mod+d exec rofi -show drun -theme ~/.config/rofi/theme.rasi
bindsym $mod+d exec rofi -show drun 
bindsym $mod+Shift+d exec rofi -show run
bindsym $mod+Shift+q kill

# Modo por defecto
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'Salir de i3?' -b 'Cierra esto' 'i3-msg exit'"

# Layouts
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# Navegación
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Mover ventanas
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right
#se arrastra la pantalla mediante raton y manteniendo pulsado windows
floating_modifier $mod 
# Workspaces
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws9 "9"
bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace $ws5

bindsym $mod+9 workspace $ws9

assign [class="Spotify"] workspace $ws9
# Mover ventanas a workspaces
bindsym $mod+Shift+1 move container to workspace $ws1
bindsym $mod+Shift+2 move container to workspace $ws2
bindsym $mod+Shift+3 move container to workspace $ws3
bindsym $mod+Shift+4 move container to workspace $ws4
bindsym $mod+Shift+5 move container to workspace $ws5
#Redimensionar las pantallas 
mode "resize" {
	bindsym Left resize shrink width 10 px or 10 ppt
	bindsym Down resize grow height 10 px or 10 ppt
	bindsym Up resize shrink height 10 px or 10 ppt
	bindsym Right resize grow width 10 px or 10 ppt

	#Vuelve al modo normal
	bindsym Return mode "default"
	bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

#full screen 
bindsym $mod+f fullscreen toggle

# Subir brillo
bindsym XF86MonBrightnessUp exec --no-startup-id brightnessctl set +10%

# Bajar brillo
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl set 10%-

#polybar posible implementacion aunque bar es mejor 

# Barra de estado
# Personalización de la barra i3
bar {
	status_command i3blocks -c ~/.config/i3blocks/config
	font pango:JetBrainsMono Nerd Font 12
    colors {
        background #1e1e2e
        statusline #c0caf5
        separator  #7aa2f7
        focused_workspace  #7aa2f7 #7aa2f7 #1e1e2e
        active_workspace   #1e1e2e #1e1e2e #c0caf5
        inactive_workspace #1e1e2e #1e1e2e #565f89
        urgent_workspace   #f38ba8 #f38ba8 #1e1e2e
    }
}

#Subir y bajar volumen
bindsym XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle

