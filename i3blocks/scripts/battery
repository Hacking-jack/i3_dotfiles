#!/bin/bash
STAT=$(cat /sys/class/power_supply/BAT1/status 2>/dev/null)
CAP=$(cat /sys/class/power_supply/BAT1/capacity 2>/dev/null)

if [ -z "$CAP" ]; then
    echo "箚겧 N/A"
    exit
fi

if [ "$STAT" = "Charging" ]; then
    ICON="箚굜"
elif [ "$CAP" -ge 90 ]; then
    ICON="箚겧"
elif [ "$CAP" -ge 70 ]; then
    ICON="箚굙"
elif [ "$CAP" -ge 50 ]; then
    ICON="箚겳"
elif [ "$CAP" -ge 20 ]; then
    ICON="箚겮"
else
    ICON="箚겫"
fi

echo "$ICON ${CAP}%"
